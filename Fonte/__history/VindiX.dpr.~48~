program VindiX;

{$APPTYPE GUI}
{$R *.res}

uses
  System.SysUtils,
  System.IOUtils,
  Winapi.Windows,
  Vcl.Forms,
  IdHTTPServer,
  IdCustomHTTPServer,
  IdContext,
  System.JSON,
  System.Classes,
  RLReport,
  RLFilters,
  RLPDFFilter,
  Winapi.ActiveX,
  RLUtils,
  UnConexao in 'UnConexao.pas',
  UnRelatorioRegistroEvolucao in 'UnRelatorioRegistroEvolucao.pas' {frmRelatorioRegistroEvolucao};

type
  TServidor = class
    Server: TIdHTTPServer;
    procedure CommandGet(AContext: TIdContext;
      ARequestInfo: TIdHTTPRequestInfo;
      AResponseInfo: TIdHTTPResponseInfo);
    procedure Iniciar;
    procedure Parar;
  end;

procedure GerarRelatorio(Codigo: Integer; Stream: TMemoryStream);
begin
  TThread.Synchronize(nil, procedure
  begin
    TFile.AppendAllText('debug.log',
      'MainForm=' + BoolToStr(Application.MainForm <> nil, True) + #13#10 +
      'ScreenPPI=' + IntToStr(ScreenPPI) + #13#10 +
      'Screen.PixelsPerInch=' + IntToStr(Screen.PixelsPerInch) + #13#10 +
      'Screen.Fonts.Count=' + IntToStr(Screen.Fonts.Count) + #13#10
    );
  end);

  CoInitializeEx(nil, COINIT_APARTMENTTHREADED);
  try
    TThread.Synchronize(nil, procedure
    var
      Relatorio: TfrmRelatorioRegistroEvolucao;
      Filter: TRLPDFFilter;
    begin
      Application.CreateForm(TfrmRelatorioRegistroEvolucao, Relatorio);
      Filter := TRLPDFFilter.Create(nil);
      try
        Relatorio.qRelatorio.Connection := Conexao;
        Relatorio.qRelatorio.Close;
        Relatorio.qRelatorio.ParamByName('pCod').AsInteger := Codigo;
        Relatorio.qRelatorio.Open;
        Relatorio.preparePaginas;
        Relatorio.RLReport1.ShowProgress := False;
        Relatorio.RLReport1.Prepare;
        Filter.ShowProgress := False;
        Filter.FilterPages(Relatorio.RLReport1.Pages, Stream);
      finally
        Filter.Free;
        Relatorio.Free;
      end;
    end);
  finally
    CoUninitialize;
  end;
end;

function ValidarLogin(Usuario, Senha: string): string;
var
  JSON: TJSONObject;
begin
  JSON := TJSONObject.Create;
  try
    // Aqui vocę conectaria ao banco depois
    // Query.SQL.Text := 'SELECT nome FROM usuarios WHERE login=:u AND senha=:s'
    if (Usuario = 'admin') and (Senha = '1234') then
    begin
      JSON.AddPair('sucesso', TJSONBool.Create(True));
      JSON.AddPair('mensagem', 'Login realizado com sucesso!');
      JSON.AddPair('nome', 'Administrador');
    end
    else
    begin
      JSON.AddPair('sucesso', TJSONBool.Create(False));
      JSON.AddPair('mensagem', 'Usuário ou senha incorretos.');
    end;

    Result := JSON.ToString;
  finally
    JSON.Free;
  end;
end;

procedure TServidor.CommandGet(AContext: TIdContext;
  ARequestInfo: TIdHTTPRequestInfo;
  AResponseInfo: TIdHTTPResponseInfo);
begin
  AResponseInfo.CustomHeaders.Add('Access-Control-Allow-Origin: *');
  AResponseInfo.CustomHeaders.Add('Access-Control-Allow-Methods: GET, POST, OPTIONS');
  AResponseInfo.CustomHeaders.Add('Access-Control-Allow-Headers: Content-Type');
  AResponseInfo.ContentType := 'application/json; charset=utf-8';

  if ARequestInfo.CommandType = hcOPTION then
  begin
    AResponseInfo.ResponseNo := 200;
    Exit;
  end;

  if ARequestInfo.Document = '/login' then
  begin
    AResponseInfo.ResponseNo := 200;
    AResponseInfo.ContentText := ValidarLogin(ARequestInfo.Params.Values['usuario'], ARequestInfo.Params.Values['senha']);
  end
  else if ARequestInfo.Document = '/imprimir' then
  begin
    var Stream := TMemoryStream.Create;
    try
      GerarRelatorio(StrToIntDef(ARequestInfo.Params.Values['codigo'], 0), Stream);
      Stream.Position := 0;

      AResponseInfo.ResponseNo  := 200;
      AResponseInfo.ContentType := 'application/pdf';
      AResponseInfo.ContentStream := Stream;
      AResponseInfo.FreeContentStream := True;
    except
      Stream.Free;
      AResponseInfo.ResponseNo  := 500;
      AResponseInfo.ContentText := '{"erro": "Erro ao gerar relatorio"}';
    end;
  end
  else
  begin
    AResponseInfo.ResponseNo := 404;
    AResponseInfo.ContentText := '{"erro": "rota nao encontrada"}';
  end;
end;

procedure TServidor.Iniciar;
begin
  Server := TIdHTTPServer.Create(nil);
  Server.DefaultPort := 8080;
  Server.OnCommandGet := CommandGet;
  Server.Active := True;
end;

procedure TServidor.Parar;
begin
  Server.Active := False;
  Server.Free;
end;

var
  Servidor: TServidor;
  FMainForm: TForm;

begin
  Application.Initialize;
  SetProcessDpiAwarenessContext(DPI_AWARENESS_CONTEXT_PER_MONITOR_AWARE_V2);
  Application.CreateForm(TForm, FMainForm);
  DC := GetDC(0);
  Screen.PixelsPerInch := GetDeviceCaps(DC, LOGPIXELSY);
  ReleaseDC(0, DC);
  ConectarBanco;
  try
    Servidor := TServidor.Create;
    Servidor.Iniciar;

    var Msg: TMsg;
    while GetMessage(Msg, 0, 0, 0) do
    begin
      TranslateMessage(Msg);
      DispatchMessage(Msg);
    end;

    Servidor.Parar;
    Servidor.Free;

    DesconectarBanco;
  except
    on E: Exception do
      TFile.AppendAllText('erro.log', E.Message);
  end;
end.
