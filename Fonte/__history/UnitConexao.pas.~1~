unit UnitConexao;

interface

uses
  System.SysUtils,
  FireDAC.Stan.Intf,
  FireDAC.Stan.Option,
  FireDAC.Stan.Error,
  FireDAC.UI.Intf,
  FireDAC.Phys.Intf,
  FireDAC.Stan.Def,
  FireDAC.Stan.Pool,
  FireDAC.Stan.Async,
  FireDAC.Phys,
  FireDAC.Phys.FB,
  FireDAC.Phys.FBDef,
  FireDAC.VCLUI.Wait,
  FireDAC.Comp.Client;

var
  Conexao: TFDConnection;

procedure ConectarBanco;
procedure DesconectarBanco;

implementation

procedure ConectarBanco;
begin
  Conexao := TFDConnection.Create(nil);

  Conexao.Params.DriverID   := 'FB';
  Conexao.Params.Database   := 'C:\banco\seubanco.fdb'; // ? caminho do banco
  Conexao.Params.UserName   := 'SYSDBA';
  Conexao.Params.Password   := 'masterkey';
  Conexao.Params.Add('CharacterSet=UTF8');

  Conexao.LoginPrompt := False;
  Conexao.Connected   := True;
end;

procedure DesconectarBanco;
begin
  if Assigned(Conexao) then
  begin
    Conexao.Connected := False;
    Conexao.Free;
  end;
end;

end.
