unit UnRelatorioRegistroEvolucaoPDF;

{
  Registro de Evolucao em PDF puro.
  Sem dependencias externas. Delphi 12 Community Edition.

  Layout fiel ao PDF original:
    - Cabecalho com logo, titulo, campos do paciente
    - Tabela de resumo com linhas horizontais por linha de texto
    - Coluna Ass/Carimbo ao lado
    - Quebra de pagina automatica mantendo o layout

  Campos esperados no qRelatorio:
    NOME_PACIENTE, IDADE, NOME_PROF, ESPECIALIDADE,
    DIAGNOSTICO, ANO, RESUMO_SESSAO
}

interface

uses
  System.SysUtils, System.Classes, FireDAC.Comp.Client,
  Vcl.Graphics, Vcl.Imaging.Jpeg;

procedure GerarRelatorioEvolucaoPDF(qRelatorio: TFDQuery; Stream: TStream;
  const CaminhoLogo: string = '');

implementation

uses
  System.StrUtils, System.Math;

// --------------------------------------------------------------------------
// Layout — A4 595x842 pts (1mm = 2.835pt)
// --------------------------------------------------------------------------
const
  PAGE_W = 595.0;
  PAGE_H = 842.0;

  // margens iguais ao original (~14mm)
  MAR_L  =  38.0;
  MAR_R  =  38.0;
  MAR_T  =  20.0;
  MAR_B  =  20.0;
  AREA_W = PAGE_W - MAR_L - MAR_R;  // 519pt

  // coluna ass/carimbo menor (~42mm = 119pt)
  COL_CARIMBO_W = 119.0;
  COL_TEXTO_W   = AREA_W - COL_CARIMBO_W;  // ~400pt
  COL_CARIMBO_X = MAR_L + COL_TEXTO_W;

  // altura de cada linha — Courier 9pt com margem
  LINE_H = 16.0;

  // fontes iguais ao original
  FS_TITULO = 18;
  FS_BOLD   = 11;
  FS_NORMAL = 10;
  FS_MONO   = 11;

  // Courier 8pt: ~5.5pt por char. Col texto ~400pt → ~72 chars
  // mantemos 69 para dar margem de seguranca
  MAX_COLS       = 58;
  MAX_LINHAS_PAG = 43;

// --------------------------------------------------------------------------
// Escape de string para PDF (latin-1 / WinAnsi)
// --------------------------------------------------------------------------
function EscapePDF(const S: string): AnsiString;
var
  I  : Integer;
  Ch : Word;
begin
  Result := '';
  for I := 1 to Length(S) do
  begin
    Ch := Ord(S[I]);
    case Ch of
      40      : Result := Result + '\(';
      41      : Result := Result + '\)';
      92      : Result := Result + '\\';
      0..39,
      43..91,
      93..127 : Result := Result + AnsiChar(Ch);
      $00C0   : Result := Result + #$C0;
      $00C1   : Result := Result + #$C1;
      $00C2   : Result := Result + #$C2;
      $00C3   : Result := Result + #$C3;
      $00C7   : Result := Result + #$C7;
      $00C9   : Result := Result + #$C9;
      $00CA   : Result := Result + #$CA;
      $00CD   : Result := Result + #$CD;
      $00D3   : Result := Result + #$D3;
      $00D4   : Result := Result + #$D4;
      $00D5   : Result := Result + #$D5;
      $00DA   : Result := Result + #$DA;
      $00DC   : Result := Result + #$DC;
      $00E0   : Result := Result + #$E0;
      $00E1   : Result := Result + #$E1;
      $00E2   : Result := Result + #$E2;
      $00E3   : Result := Result + #$E3;
      $00E7   : Result := Result + #$E7;
      $00E9   : Result := Result + #$E9;
      $00EA   : Result := Result + #$EA;
      $00ED   : Result := Result + #$ED;
      $00F1   : Result := Result + #$F1;
      $00F3   : Result := Result + #$F3;
      $00F4   : Result := Result + #$F4;
      $00F5   : Result := Result + #$F5;
      $00FA   : Result := Result + #$FA;
      $00FC   : Result := Result + #$FC;
    else
      Result := Result + '?';
    end;
  end;
end;

// --------------------------------------------------------------------------
// Quebra de texto — porta fiel da funcao original QuebrarTexto
// Retorna TStringList com linhas e '---QUEBRA_PAGINA---' nos limites
// --------------------------------------------------------------------------
function QuebrarTexto(const Texto: string; MaxLinhas, MaxCols: Integer): TStringList;
var
  LinhasEntrada : TStringList;
  Linha, Temp, Palavra : string;
  I, CountLinhas : Integer;
begin
  LinhasEntrada := TStringList.Create;
  Result        := TStringList.Create;
  LinhasEntrada.Text := Texto;
  Linha       := '';
  I           := 0;
  CountLinhas := 0;

  while I < LinhasEntrada.Count do
  begin
    Temp := LinhasEntrada[I];
    Inc(I);

    if Result.Count = MAX_LINHAS_PAG then
    begin
      CountLinhas := 0;
      Result.Add('---QUEBRA_PAGINA---');
    end;

    if Trim(Temp) = '' then
    begin
      Result.Add('');
      Inc(CountLinhas);
      Continue;
    end;

    while Temp <> '' do
    begin
      Palavra := Copy(Temp, 1, Pos(' ', Temp + ' ') - 1);

      // palavra maior que a coluna: corta
      if Length(Palavra) > MaxCols then
      begin
        if Length(Linha) > 0 then
          Palavra := Copy(Palavra, 1, MaxCols - Length(Linha) - 1)
        else
          Palavra := Copy(Palavra, 1, MaxCols - Length(Linha));
      end;

      if (Length(Linha) + Length(Palavra) + 1 <= MaxCols) or
         ((Linha = '') and (Length(Palavra) = MaxCols)) then
      begin
        if Linha = '' then
          Linha := Palavra
        else
          Linha := Linha + ' ' + Palavra;
        Delete(Temp, 1, Length(Palavra) + 1);
      end
      else
      begin
        if Result.Count = MAX_LINHAS_PAG then
        begin
          CountLinhas := 0;
          Result.Add('---QUEBRA_PAGINA---');
        end;
//        if CountLinhas = MaxLinhas then
//        begin
//          CountLinhas := 0;
//          Result.Add('---QUEBRA_PAGINA---');
//        end;
        Result.Add(Linha);
        Inc(CountLinhas);
        Linha := '';
      end;
    end;

    if Linha <> '' then
    begin
      if Result.Count = MAX_LINHAS_PAG then
      begin
        CountLinhas := 0;
        Result.Add('---QUEBRA_PAGINA---');
      end;
//      if CountLinhas = MaxLinhas then
//      begin
//        CountLinhas := 0;
//        Result.Add('---QUEBRA_PAGINA---');
//      end;
      Result.Add(Linha);
      Inc(CountLinhas);
      Linha := '';
    end;
  end;

  if 37 > Result.Count then
  begin
    while Result.Count < 37 do
    begin
      Result.Add('');
    end;
  end
  else if MAX_LINHAS_PAG > CountLinhas then
  begin
    while CountLinhas < MAX_LINHAS_PAG do
    begin
      inc(CountLinhas);
      Result.Add('');
    end;
  end;

  LinhasEntrada.Free;
end;

// --------------------------------------------------------------------------
// Geracao do PDF
// --------------------------------------------------------------------------
procedure GerarRelatorioEvolucaoPDF(qRelatorio: TFDQuery; Stream: TStream;
  const CaminhoLogo: string = '');
var
  GFS       : TFormatSettings;
  Pages     : array of AnsiString;
  PageCount : Integer;
  CurCmds   : TStringList;
  CurY      : Double;
  Out       : TMemoryStream;
  Offsets   : array of Int64;
  ObjN       : Integer;
  ImgObjId   : Integer;
  ImgStream  : TMemoryStream;

  // ---- escrita ----

  function Fmt(const Mask: string; const Args: array of const): AnsiString;
  begin
    Result := AnsiString(Format(Mask, Args, GFS));
  end;

  procedure WS(const S: AnsiString);
  begin
    if S <> '' then Out.Write(S[1], Length(S));
  end;

  procedure WL(const S: AnsiString);
  begin
    WS(S + #10);
  end;

  function NO: Integer;
  begin
    Inc(ObjN);
    Result := ObjN;
    if Result > Length(Offsets) then
      SetLength(Offsets, Length(Offsets) * 2);
    Offsets[Result - 1] := Out.Position;
    WL(AnsiString(IntToStr(Result) + ' 0 obj'));
  end;

  procedure EO;
  begin
    WL('endobj');
  end;

  function EscreverJPEG(Data: TMemoryStream; W, H: Integer): Integer;
  var Buf: array of Byte; Sz: Integer;
  begin
    Sz := Data.Size;
    SetLength(Buf, Sz);
    Data.Position := 0;
    Data.Read(Buf[0], Sz);
    Result := NO;
    WL(Fmt('<< /Type /XObject /Subtype /Image /Width %d /Height %d', [W, H]));
    WL('/ColorSpace /DeviceRGB /BitsPerComponent 8');
    WL(Fmt('/Filter /DCTDecode /Length %d >>', [Sz]));
    WL('stream');
    Out.Write(Buf[0], Sz);
    WS(#10);
    WL('endstream');
    EO;
  end;


  // ---- comandos de desenho ----

  procedure SetFH(Sz: Integer; Bold: Boolean);
  begin
    if Bold then CurCmds.Add(Format('/F2 %d Tf', [Sz]))
    else         CurCmds.Add(Format('/F1 %d Tf', [Sz]));
  end;

  procedure SetFC(Sz: Integer);
  begin
    CurCmds.Add(Format('/F3 %d Tf', [Sz]));
  end;

  procedure PT(const S: string; X, Y: Double);
  begin
    CurCmds.Add(string(Fmt('BT %.2f %.2f Td (%s) Tj ET',
      [X, PAGE_H - Y, string(EscapePDF(S))])));
  end;

  procedure PL(X1, Y1, X2, Y2: Double);
  begin
    CurCmds.Add(string(Fmt('%.2f %.2f m %.2f %.2f l S',
      [X1, PAGE_H - Y1, X2, PAGE_H - Y2])));
  end;

  procedure HL(X1, Y, X2: Double); begin PL(X1, Y, X2, Y); end;
  procedure VL(X, Y1, Y2: Double); begin PL(X, Y1, X, Y2); end;

  procedure Bx(X, Y, W, H: Double);
  begin
    HL(X,     Y,     X + W);
    HL(X,     Y + H, X + W);
    VL(X,     Y,     Y + H);
    VL(X + W, Y,     Y + H);
  end;

  procedure Bd(const S: string; X, Y: Double; Sz: Integer);
  begin SetFH(Sz, True);  PT(S, X, Y); end;

  procedure Nr(const S: string; X, Y: Double; Sz: Integer);
  begin SetFH(Sz, False); PT(S, X, Y); end;

  procedure Mn(const S: string; X, Y: Double; Sz: Integer);
  begin SetFC(Sz); PT(S, X, Y); end;

  // ---- controle de paginas ----

  procedure FlushPage;
  var
    Buf : AnsiString;
    I   : Integer;
  begin
    Buf := '';
    for I := 0 to CurCmds.Count - 1 do
      Buf := Buf + AnsiString(CurCmds[I]) + #10;
    Inc(PageCount);
    if PageCount > Length(Pages) then
      SetLength(Pages, Length(Pages) * 2);
    Pages[PageCount - 1] := Buf;
    CurCmds.Clear;
  end;

  procedure NewPage;
  begin
    CurCmds.Clear;
    CurCmds.Add('0.4 w');
    CurY := MAR_T;
  end;

  // ---- cabecalho da primeira pagina ----

  procedure Cab1(const NomePac, Idade, Prof, Esp, Diag, Ano: string);
  var
    Y, RDir, MeioX: Double;
  const
    G = 22.0;   // gap vertical entre linhas do cabecalho
    L = 1.0;    // gap entre fim do label e inicio do valor
  begin
    Y    := CurY;
    RDir := MAR_L + AREA_W;

    // --- Logo ---
    if ImgStream.Size > 0 then
    begin
      var Img3 := TJPEGImage.Create;
      try
        ImgStream.Position := 0;
        Img3.LoadFromStream(ImgStream);
        var IW := Img3.Width;
        var IH := Img3.Height;
        var FitW := 110.0;
        var FitH := 105.0;
        var ScaleW := FitW / IW;
        var ScaleH := FitH / IH;
        var Scale  := Min(ScaleW, ScaleH);
        var DrawW  := IW * Scale;
        var DrawH  := IH * Scale;
        CurCmds.Add(string(Fmt('q %.2f 0 0 %.2f %.2f %.2f cm /Im1 Do Q',
          [DrawW, DrawH, MAR_L, PAGE_H - (Y + DrawH)])));
      finally
        Img3.Free;
      end;
    end;

    // --- Titulo centralizado na PAGINA INTEIRA ---
    SetFH(FS_TITULO, True);
    PT('Registro  de  evolucao', 210, Y + 38);

    Y := Y + 95;  // menos espaco entre logo e campos

    // --- Ano: label + linha + valor ---
    SetFH(FS_BOLD, True);
    PT('Ano:', RDir - 91, Y);
    HL(RDir - 64, Y + 2, RDir);
    SetFH(FS_NORMAL, False);
    PT(Ano, RDir - 42, Y);

    Y := Y + G;

    // --- Nome do paciente | Idade ---
    // linha da Idade começa logo apos o label "Idade:" (RDir-106+42 = RDir-64... ~RDir-108+2)
    // para ficar colado: linha comeca em RDir-106+40+2 = RDir-64
    // mas isso deixa linha muito curta, melhor: linha de RDir-106 ate RDir
    // ou seja a linha começa onde o label começa, abaixo dele
    SetFH(FS_BOLD, True);
    PT('Paciente:', MAR_L, Y);
    SetFH(FS_NORMAL, False);
    PT(NomePac, MAR_L + 52 + L, Y);
    HL(MAR_L + 50, Y + 2, RDir - 108);  // linha nome

    // "Idade:" = ~38pt, label em RDir-106, linha logo apos em RDir-106+38+2 = RDir-66
    SetFH(FS_BOLD, True);
    PT('Idade:', RDir - 98, Y);
    SetFH(FS_NORMAL, False);
    PT(Idade, RDir - 39, Y);
    HL(RDir - 64, Y + 2, RDir);

    Y := Y + G;

    // --- Profissional | Especialidade ---
    MeioX := MAR_L + AREA_W * 0.5;
    SetFH(FS_BOLD, True);
    PT('Profissional:', MAR_L, Y);
    SetFH(FS_NORMAL, False);
    PT(Prof, MAR_L + 70 + L, Y);
    HL(MAR_L + 68, Y + 2, MeioX - 5);   // linha colada ao label

    SetFH(FS_BOLD, True);
    PT('Especialidade:', MeioX, Y);
    SetFH(FS_NORMAL, False);
    PT(Esp, MeioX + 80 + L, Y);
    HL(MeioX + 78, Y + 2, RDir);        // linha colada ao label

    Y := Y + G;

    // --- Diagnostico ---
    SetFH(FS_BOLD, True);
    PT('Diagnostico:', MAR_L, Y);
    SetFH(FS_NORMAL, False);
    PT(Diag, MAR_L + 70 + L, Y);
    HL(MAR_L + 68, Y + 2, RDir);        // linha colada ao label

    Y := Y + G + 4;  // espaco extra antes dos rotulos

    // --- Rotulos das colunas ---
    SetFH(FS_BOLD, True);
    PT('Resumo da sessao:', MAR_L, Y);
    PT('Ass/Carimbo:', COL_CARIMBO_X + 4, Y);

    CurY := Y + 8;
  end;

  procedure CabCont;
  begin
    // paginas de continuacao comecam direto o conteudo
  end;

  function LinhasCabem: Integer;
  begin
    Result := Trunc((PAGE_H - MAR_B - CurY) / LINE_H);
    if Result < 1 then Result := 0;
  end;

  procedure DesenhaBloco(Linhas: TStringList; Ini, Fim: Integer);
  var
    N, J   : Integer;
    BoxH   : Double;
    LY     : Double;
    Idx    : Integer;
    Txt    : string;
  begin
    N := Fim - Ini + 1;
    if N <= 0 then Exit;
    BoxH := N * LINE_H;

    // bordas externas
    Bx(MAR_L,         CurY, COL_TEXTO_W,   BoxH);
    Bx(COL_CARIMBO_X, CurY, COL_CARIMBO_W, BoxH);

    for J := 0 to N - 1 do
    begin
      LY  := CurY + J * LINE_H;
      Idx := Ini + J;

      // linhas internas horizontais
      if J > 0 then
      begin
        HL(MAR_L,         LY, MAR_L + COL_TEXTO_W);
        HL(COL_CARIMBO_X, LY, COL_CARIMBO_X + COL_CARIMBO_W);
      end;

      // texto da linha
      if Idx < Linhas.Count then
      begin
        Txt := Linhas[Idx];
        if (Txt <> '') and (Txt <> '---QUEBRA_PAGINA---') then
        begin
          SetFC(FS_MONO);
          PT(' ' + Txt, MAR_L + 2, LY + LINE_H - 3.5);
        end;
      end;
    end;

    CurY := CurY + BoxH;
  end;

// ---- CORPO PRINCIPAL ----
var
  Linhas              : TStringList;
  BIni, BFim, C, I   : Integer;
  Kids                : AnsiString;
  XP                  : Int64;
  StreamId            : Integer;
  NomePac, Idade      : string;
  Prof, Esp, Diag     : string;
  Ano, Texto          : string;
  PosAtual            : Integer;
begin
  GFS := TFormatSettings.Invariant;

  CurCmds   := TStringList.Create;
  Linhas    := nil;
  PageCount := 0;
  ObjN      := 0;
  SetLength(Pages,   16);
  SetLength(Offsets, 256);
  Out := TMemoryStream.Create;

  try
    // carrega logo se informado
    ImgObjId := 0;
    ImgStream := TMemoryStream.Create;
    try
      if (CaminhoLogo <> '') and FileExists(CaminhoLogo) then
      begin
        var Img := TJPEGImage.Create;
        try
          Img.LoadFromFile(CaminhoLogo);
          Img.SaveToStream(ImgStream);
        finally
          Img.Free;
        end;
      end;
    except
      ImgStream.Clear;
    end;

    // le dados do dataset
    NomePac := qRelatorio.FieldByName('NOME_PACIENTE').AsString;
    Idade   := qRelatorio.FieldByName('IDADE').AsString;
    Prof    := qRelatorio.FieldByName('NOME_PROF').AsString;
    Esp     := qRelatorio.FieldByName('ESPECIALIDADE').AsString;
    Diag    := qRelatorio.FieldByName('DIAGNOSTICO').AsString;
    Ano     := qRelatorio.FieldByName('ANO').AsString;
    Texto   := qRelatorio.FieldByName('RESUMO_SESSAO').AsString;

    // quebra o texto com MaxLinhas=61 e MAX_COLS=69
    Linhas := QuebrarTexto(Texto, 61, MAX_COLS);

    // ---- Fase 1: gera conteudo de cada pagina ----
    NewPage;
    Cab1(NomePac, Idade, Prof, Esp, Diag, Ano);

    PosAtual := 0;
    while PosAtual < Linhas.Count do
    begin
      // pula marcadores de quebra (sao ignorados — o loop controla as quebras)
      if Linhas[PosAtual] = '---QUEBRA_PAGINA---' then
      begin
        Inc(PosAtual);
        Continue;
      end;

      // quantas linhas cabem na pagina atual
      C := LinhasCabem;
      if C <= 0 then
      begin
        FlushPage;
        NewPage;
        CabCont;
        Continue;
      end;

      // monta bloco de C linhas ignorando marcadores
      BIni := PosAtual;
      var LinhasBloco := TStringList.Create;
      try
        var Cont := 0;
        var Idx  := PosAtual;
        while (Idx < Linhas.Count) and (Cont < C) do
        begin
          if Linhas[Idx] <> '---QUEBRA_PAGINA---' then
          begin
            LinhasBloco.Add(Linhas[Idx]);
            Inc(Cont);
          end;
          Inc(Idx);
        end;
        PosAtual := Idx;

        // desenha o bloco
        if LinhasBloco.Count > 0 then
          DesenhaBloco(LinhasBloco, 0, LinhasBloco.Count - 1);
      finally
        LinhasBloco.Free;
      end;

      // se ainda ha conteudo, nova pagina
      if PosAtual < Linhas.Count then
      begin
        // avanca marcadores
        while (PosAtual < Linhas.Count) and
              (Linhas[PosAtual] = '---QUEBRA_PAGINA---') do
          Inc(PosAtual);

        if PosAtual < Linhas.Count then
        begin
          FlushPage;
          NewPage;
          CabCont;
        end;
      end;
    end;
    FlushPage;

    // ---- Fase 2: monta o PDF ----
    WL('%PDF-1.4');

    // obj 1 = catalogo
    NO;
    WL('<< /Type /Catalog /Pages 2 0 R >>');
    EO;

    // obj 2 = page tree
    // Com imagem: obj3=imagem, obj4=recursos, paginas comecam no obj5 (stream=5,page=6; stream=7,page=8...)
    // Sem imagem: obj3=recursos, paginas comecam no obj4 (stream=4,page=5; stream=6,page=7...)
    NO;
    Kids := '';
    var PageBase := 4;  // base sem imagem
    if ImgStream.Size > 0 then PageBase := 5;  // com imagem desloca 1
    for I := 0 to PageCount - 1 do
    begin
      if I > 0 then Kids := Kids + ' ';
      Kids := Kids + Fmt('%d 0 R', [PageBase + 1 + I * 2]);
    end;
    WL(Fmt('<< /Type /Pages /Count %d /Kids [%s] >>', [PageCount, string(Kids)]));
    EO;

    // obj 3 = imagem (opcional)
    if ImgStream.Size > 0 then
    begin
      var Img2 := TJPEGImage.Create;
      try
        ImgStream.Position := 0;
        Img2.LoadFromStream(ImgStream);
        ImgObjId := EscreverJPEG(ImgStream, Img2.Width, Img2.Height);
      finally
        Img2.Free;
      end;
    end;

    // obj seguinte = recursos (fontes + XObject se tiver imagem)
    var ResObjId := NO;
    WL('<< /Font <<');
    WL('  /F1 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica /Encoding /WinAnsiEncoding >>');
    WL('  /F2 << /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold /Encoding /WinAnsiEncoding >>');
    WL('  /F3 << /Type /Font /Subtype /Type1 /BaseFont /Courier /Encoding /WinAnsiEncoding >>');
    WL('>>');
    if ImgObjId > 0 then
      WL(Fmt('/XObject << /Im1 %d 0 R >>', [ImgObjId]));
    WL('>>');
    EO;

    // obj N+ = pares (stream_conteudo, pagina)
    for I := 0 to PageCount - 1 do
    begin
      StreamId := NO;
      WL(Fmt('<< /Length %d >>', [Length(Pages[I])]));
      WL('stream');
      WS(Pages[I]);
      WL('endstream');
      EO;

      NO;
      WL(Fmt(
        '<< /Type /Page /Parent 2 0 R /MediaBox [0 0 595 842] ' +
        '/Resources %d 0 R /Contents %d 0 R >>',
        [ResObjId, StreamId]));
      EO;
    end;

    // xref
    XP := Out.Position;
    WL('xref');
    WL(Fmt('0 %d', [ObjN + 1]));
    WL('0000000000 65535 f ');
    for I := 0 to ObjN - 1 do
      WL(Fmt('%.10d 00000 n ', [Offsets[I]]));
    WL('trailer');
    WL(Fmt('<< /Size %d /Root 1 0 R >>', [ObjN + 1]));
    WL('startxref');
    WL(Fmt('%d', [XP]));
    WL('%%EOF');

    Out.Position := 0;
    Stream.CopyFrom(Out, Out.Size);

  finally
    if Assigned(ImgStream) then ImgStream.Free;
    Out.Free;
    CurCmds.Free;
    if Assigned(Linhas) then Linhas.Free;
  end;
end;

end.
