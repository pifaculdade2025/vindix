procedure TfrmRelatorioRegistroEvolucao.preparePaginas;
var
  I: integer;
begin
  PosicaoSobra := 0;

  sTextoCompleto := '';

  if self.Tag = 2 then
  begin
    qRelatorio.First;
    while not qRelatorio.Eof do
    begin
      sTextoCompleto := sTextoCompleto + ifthen(sTextoCompleto <> '', #13#10#13#10) + 'Sess緌: ' +
                        qRelatorio.FieldByName('DT_HR_SESSAO').AsString + #13#10 +
                        Trim(qRelatorio.FieldByName('RESUMO_SESSAO').AsString);
      qRelatorio.Next;
    end;
    qRelatorio.First;
  end
  else
    sTextoCompleto := qRelatorio.FieldByName('RESUMO_SESSAO').AsString;

  stlTextos := QuebrarTexto(sTextoCompleto, 61, 66);

  cdsResumo.Close;
  cdsResumo.CreateDataSet;
  for i := 1 to inpaginas-1 do
  begin
    cdsResumo.Append;
    cdsResumo.FieldByName('ID').AsInteger := i;
    cdsResumo.Post;
  end;
  cdsResumo.First;
  cdsResumo.Open;
end;

function TfrmRelatorioRegistroEvolucao.QuebrarTexto(const Texto: string;
  MaxLinhas, MaxCols: Integer): TStringList;
var
  LinhasEntrada, Paginas: TStringList;
  Linha, Temp, Palavra: string;
  i, CountLinhas: Integer;
begin
  LinhasEntrada := TStringList.Create;
  Paginas := TStringList.Create;
  LinhasEntrada.Text := Texto;

  Linha := '';
  i := 0;
  CountLinhas := 0;
  inpaginas := 1;

  if Texto = '' then
  begin
    for I := 1 to 103 do
    begin
      if Paginas.Count = 42 then
      begin
        if PosicaoSobra = 0 then
          PosicaoSobra := Paginas.count + 1;
        Paginas.Add('---QUEBRA_PAGINA---');
      end;
      Paginas.Add('');
    end;
    inpaginas := 1;
    Result := Paginas;
    Exit;
  end;

  while i < LinhasEntrada.Count do
  begin
    Temp := LinhasEntrada[i];
    Inc(i);

    if Paginas.Count = 42 then
    begin
      CountLinhas := 0;
      if PosicaoSobra = 0 then
        PosicaoSobra := Paginas.count + 1;
      Paginas.Add('---QUEBRA_PAGINA---');
      inc(inpaginas);
    end;

    if Trim(Temp) = '' then
    begin
      Paginas.Add('');
      Inc(CountLinhas);
      Continue;
    end;

    while Temp <> '' do
    begin
      Palavra := Copy(Temp, 1, Pos(' ', Temp + ' ') - 1);

      if Length(palavra) > MaxCols then
      begin
        if Length(linha) > 0 then
          palavra := Copy(palavra, 1, maxCols - length(linha) - 1)
        else
          palavra := Copy(palavra, 1, maxCols - length(linha));
      end;

      if (Length(Linha) + Length(Palavra) + 1 <= MaxCols) or ((Linha = '') and (length(palavra) = MaxCols)) then
      begin
        if Linha = '' then
          Linha := Palavra
        else
          Linha := Linha + ' ' + Palavra;

        Delete(Temp, 1, Length(Palavra) + 1);
      end
      else
      begin
        if Paginas.Count = 42 then
        begin
          CountLinhas := 0;
          if PosicaoSobra = 0 then
            PosicaoSobra := Paginas.count + 1;
          Paginas.Add('---QUEBRA_PAGINA---');
          inc(inpaginas);
        end;

        if CountLinhas = MaxLinhas then
        begin
          CountLinhas := 0;
          Paginas.Add('---QUEBRA_PAGINA---');
          inc(inpaginas);
        end;

        Paginas.Add(Linha);
        Inc(CountLinhas);
        Linha := '';
      end;
    end;

    if Linha <> '' then
    begin
      if Paginas.Count = 42 then
      begin
        CountLinhas := 0;
        if PosicaoSobra = 0 then
          PosicaoSobra := Paginas.count + 1;
        Paginas.Add('---QUEBRA_PAGINA---');
        inc(inpaginas);
      end;

      if CountLinhas = MaxLinhas then
      begin
        CountLinhas := 0;
        Paginas.Add('---QUEBRA_PAGINA---');
        inc(inpaginas);
      end;

      Paginas.Add(Linha);
      Inc(CountLinhas);
      Linha := '';
    end;
  end;

  Result := Paginas;
end;

